<div class="flex justify-between items-center mb-4">
    <h1 class="text-2xl font-bold">DATA MAHASISWA BERHASIL MUNCUL!</h1>
<ul>
  <% mahasiswa.forEach(m => { %>
    <li><%= m.nama %> - <%= m.nim %></li>
  <% }) %>
</ul>
    <a href="/mahasiswa/create" class="bg-green-500 hover:bg-green-600 text-white px-4 py-2 rounded">
        + Tambah Mahasiswa
    </a>
</div>

<table class="w-full border-collapse border border-gray-200">
    <thead>
        <tr class="bg-gray-50">
            <th class="border p-3 text-left">Nama</th>
            <th class="border p-3 text-left">NIM</th>
            <th class="border p-3 text-center">Aksi</th>
        </tr>
    </thead>
    <tbody>
        <% if (mahasiswa.length > 0) { %>
            <% mahasiswa.forEach(m => { %>
                <tr class="hover:bg-gray-50">
                    <td class="border p-3"><%= m.nama %></td>
                    <td class="border p-3"><%= m.nim %></td>
                    <td class="border p-3 text-center">
                        <button class="text-blue-500 mr-2">Edit</button>
                        <button class="text-red-500">Hapus</button>
                    </td>
                </tr>
            <% }) %>
        <% } else { %>
            <tr>
                <td colspan="3" class="border p-10 text-center text-gray-500 italic">
                    Belum ada data mahasiswa. Silakan tambah data.
                </td>
            </tr>
        <% } %>
    </tbody>
</table>