<div class="bg-white p-6 rounded-2xl shadow">
  <div class="flex justify-between items-center mb-4">
    <h2 class="text-xl font-bold">Data Mahasiswa</h2>
    <a href="/mahasiswa/create" class="bg-blue-500 text-white px-4 py-2 rounded">+ Tambah</a>
  </div>
  
  <% if (success) { %>
    <div class="bg-green-100 text-green-700 p-3 rounded mb-4"><%= success %></div>
  <% } %>

  <table class="w-full text-left border-collapse">
    <thead>
      <tr class="bg-gray-200">
        <th class="p-3 border-b">No</th>
        <th class="p-3 border-b">Nama</th>
        <th class="p-3 border-b">NIM</th>
        <th class="p-3 border-b">Aksi</th>
      </tr>
    </thead>
    <tbody>
      <% mahasiswa.forEach((m, index) => { %>
        <tr class="hover:bg-gray-50">
          <td class="p-3 border-b"><%= index + 1 %></td>
          <td class="p-3 border-b"><%= m.nama %></td>
          <td class="p-3 border-b"><%= m.nim %></td>
          <td class="p-3 border-b">
            <a href="/mahasiswa/edit/<%= m.id %>" class="text-yellow-500 mr-2">Edit</a>
            <a href="/mahasiswa/delete/<%= m.id %>" onclick="return confirm('Yakin? Data akan dihapus permanen!')" class="text-red-500">Hapus</a>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>